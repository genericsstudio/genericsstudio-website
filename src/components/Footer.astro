---
import GenericsStudioLogo from "@/components/svgs/GenericsStudioLogo.astro";
import { useTranslations } from "@/i18n/utils";

const { t, tRaw } = useTranslations("de");

type FooterLink = { label: string; href: string };
const links = tRaw<FooterLink[]>("footer.links");
---

<footer class="border-t border-white/6 pt-16 pb-12 px-6 md:px-10 mt-0">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-block mb-4">
          <GenericsStudioLogo class="h-7 w-auto text-foreground opacity-60 hover:opacity-90 transition-opacity" />
        </a>
        <p class="text-label text-foreground-dimmer leading-[1.7] fw-400 max-w-[220px]">
          Design- und Webagentur aus der Schweiz.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <p class="text-label fw-510 uppercase tracking-[0.12em] text-foreground-dimmer mb-4">{t("footer.pages")}</p>
        <ul class="flex flex-col gap-2.5">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-label text-muted-foreground hover:text-secondary-foreground transition-colors fw-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <p class="text-label fw-510 uppercase tracking-[0.12em] text-foreground-dimmer mb-4">Leistungen</p>
        <ul class="flex flex-col gap-2.5">
          {[
            { label: "Webdesign",    href: "/webdesign"     },
            { label: "Branding",     href: "/branding"      },
            { label: "Grafikdesign", href: "/graphicdesign" },
          ].map((link) => (
            <li>
              <a
                href={link.href}
                class="text-label text-muted-foreground hover:text-secondary-foreground transition-colors fw-400"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-label fw-510 uppercase tracking-[0.12em] text-foreground-dimmer mb-4">Kontakt</p>
        <ul class="flex flex-col gap-2.5">
          <li>
            <a href="mailto:hello@generics.studio" class="text-label text-muted-foreground hover:text-secondary-foreground transition-colors fw-400">
              hello@generics.studio
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/genericsstudio" target="_blank" rel="noopener" class="text-label text-muted-foreground hover:text-secondary-foreground transition-colors fw-400">
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/5 pt-6 flex flex-col sm:flex-row justify-between gap-3">
      <p class="text-label text-foreground-dimmer fw-400">
        &copy; {new Date().getFullYear()} Gurgurovci Studio. {t("footer.copyright")}
      </p>
      <a href="/imprint" class="text-label text-foreground-dimmer hover:text-muted-foreground transition-colors fw-400">
        {t("footer.imprint")}
      </a>
    </div>
  </div>
</footer>
