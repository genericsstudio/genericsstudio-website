---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import WebdesignComparison from "@/components/sections/WebdesignComparison.astro";
import WebdesignFeatures from "@/components/sections/WebdesignFeatures.astro";
import ServicePricing from "@/components/sections/ServicePricing.astro";
import ServiceFAQ from "@/components/sections/ServiceFAQ.astro";
import { useTranslations } from "@/i18n/utils";
import { pricing, PRICES } from "@/config/pricing";

const { t, tRaw } = useTranslations();

type PricingCta = { title: string; description: string; button: string };
type FaqItem = { question: string; answer: string };

const siteUrl = "https://generics.studio";
const faqItems = tRaw<FaqItem[]>("pages.webdesign.faq.items");

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Webdesign & Entwicklung",
  serviceType: "Webdesign",
  description: t("pages.webdesign.meta.description"),
  provider: { "@id": `${siteUrl}/#organization` },
  areaServed: [
    { "@type": "City", name: "Wil" },
    { "@type": "AdministrativeArea", name: "Kanton St. Gallen" },
    { "@type": "Country", name: "Schweiz" },
  ],
  offers: { "@type": "AggregateOffer", lowPrice: String(PRICES.webdesign.starter), priceCurrency: "CHF", offerCount: "3" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Webdesign", item: `${siteUrl}/webdesign` },
  ],
};
---

<Layout
  title={t("pages.webdesign.meta.title")}
  description={t("pages.webdesign.meta.description")}
  schema={[serviceSchema, breadcrumbSchema, faqSchema]}
>
  <main>
    <PageHeader
      title={t("pages.webdesign.header.title")}
      description={t("pages.webdesign.header.description")}
    />
    <WebdesignComparison locale="de" />
    <WebdesignFeatures locale="de" />
    <ServicePricing
      title={t("pages.webdesign.pricing.title")}
      description={t("pages.webdesign.pricing.description")}
      note={t("pages.webdesign.pricing.note")}
      cta={tRaw<PricingCta>("pages.webdesign.pricing.cta")}
      plans={pricing.webdesign.plans}
    />
    <ServicePricing
      title={t("pages.webdesign.hosting.title")}
      description={t("pages.webdesign.hosting.description")}
      note={t("pages.webdesign.hosting.note")}
      cta={tRaw<PricingCta>("pages.webdesign.hosting.cta")}
      plans={pricing.webdesign.hosting.plans}
    />
    <ServiceFAQ
      title={t("pages.webdesign.faq.title")}
      items={faqItems}
    />
  </main>
</Layout>
