---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import Mission from "@/components/sections/Mission.astro";
import Services from "@/components/sections/Services.astro";
import Process from "@/components/sections/Process.astro";
import Pricing from "@/components/sections/Pricing.astro";
import CTA from "@/components/sections/CTA.astro";
import { useTranslations } from "@/i18n/utils";
import { homePricingItems } from "@/config/pricing";

const { t, tRaw } = useTranslations();

type Benefit = { number: string; title: string; description: string };
type ServiceItem = { number: string; title: string; description: string; href: string };
type Step = { number: string; title: string; description: string };
type PricingCta = { title: string; description: string; button: string };

const siteUrl = "https://generics.studio";

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/`,
  name: t("hero.meta.title"),
  description: t("hero.meta.description"),
  url: `${siteUrl}/`,
  isPartOf: { "@id": `${siteUrl}/#website` },
  about: { "@id": `${siteUrl}/#organization` },
  inLanguage: "de-CH",
};
---

<Layout
  title={t("hero.meta.title")}
  description={t("hero.meta.description")}
  schema={homeSchema}
>
  <main>
    <Hero
      badge={t("hero.badge")}
      title={t("hero.title")}
      subtitle={t("hero.subtitle")}
      description={t("hero.description")}
      ctaLabel={t("hero.cta")}
      ctaSecondary={t("hero.ctaSecondary")}
    />

    <Mission
      label={t("mission.label")}
      title={t("mission.title")}
      subtitle={t("mission.subtitle")}
      description={t("mission.description")}
      benefits={tRaw<Benefit[]>("mission.benefits")}
    />

    <Services
      label={t("services.label")}
      title={t("services.title")}
      subtitle={t("services.subtitle")}
      more={t("services.more")}
      items={tRaw<ServiceItem[]>("services.items")}
    />

    <Process
      label={t("process.label")}
      title={t("process.title")}
      subtitle={t("process.subtitle")}
      description={t("process.description")}
      steps={tRaw<Step[]>("process.steps")}
    />

    <Pricing
      label={t("pricing.label")}
      title={t("pricing.title")}
      subtitle={t("pricing.subtitle")}
      description={t("pricing.description")}
      cta={tRaw<PricingCta>("pricing.cta")}
      items={homePricingItems}
    />

    <CTA
      label={t("cta.label")}
      title={t("cta.title")}
      subtitle={t("cta.subtitle")}
      button={t("cta.button")}
    />
  </main>
</Layout>
